                  "});",
                  "",
                  "pm.test('Response has quota info or unlimited flag', function () {",
                  "  const body = pm.response.json();",
                  "  if (body.unlimited) {",
                  "    pm.expect(body.unlimited).to.be.true;",
                  "  } else {",
                  "    pm.expect(body).to.have.property('maxBytes');",
                  "    pm.expect(body).to.have.property('usedBytes');",
                  "    pm.expect(body).to.have.property('availableBytes');",
                  "    pm.expect(body).to.have.property('percentUsed');",
                  "    pm.expect(body.maxBytes).to.be.a('number');",
                  "    pm.expect(body.usedBytes).to.be.a('number');",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
