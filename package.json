{
  "name": "own-drive",
  "type": "module",
  "version": "1.8.1",
  "private": true,
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0",
    "start": "node ./dist/server/entry.mjs",
    "db:migrate": "node src/db/migrate.js up",
    "db:status": "node src/db/migrate.js status",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@astrojs/lit": "^4.3.0",
    "@astrojs/node": "^9.5.3",
    "archiver": "^7.0.1",
    "astro": "^5.17.2",
    "dicom-parser": "^1.8.21",
    "jose": "^6.1.3",
    "jpeg-lossless-decoder-js": "^2.1.2",
    "lit": "^3.2.0",
    "marked": "^17.0.4",
    "node-cron": "^4.2.1",
    "pg": "^8.13.0",
    "@faker-js/faker": "^10.4.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
