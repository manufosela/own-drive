# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=geniova_drive
POSTGRES_USER=geniova
POSTGRES_PASSWORD=changeme_in_production

# App
APP_PORT=3000
APP_HOST=0.0.0.0

# NAS mount points (inside container)
NAS_DATOSNAS=/mnt/datosnas
NAS_NOCOMUN=/mnt/no-comun

# Auth&Sign
AUTH_SIGN_URL=https://auth.geniova.com
AUTH_APP_ID=geniova-drive

# Server (production)
SERVER_IP=192.168.63.124
PUBLIC_URL=https://drive.geniova.com

# Firebase (Auth&Sign - public config)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=geniova-auth.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=geniova-auth
PUBLIC_FIREBASE_STORAGE_BUCKET=geniova-auth.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
